+
+function buildHrtWellnessChart(scored) {
+  if (!scored.length) return '<div class="hrt-empty">Недостаточно оценок для графика.</div>';
+  const width = 300, height = 110;
+  const step = scored.length > 1 ? width / (scored.length - 1) : 0;
+  const yOf = score => 102 - (score / 100) * 94;
+  const points = scored.map((x,i) => `${(scored.length > 1 ? i * step : width/2).toFixed(1)},${yOf(x.score).toFixed(1)}`).join(' ');
+  const dots = scored.map((x,i) => {
+    const cx = (scored.length > 1 ? i * step : width/2).toFixed(1);
+    const cy = yOf(x.score).toFixed(1);
+    return `<circle cx="${cx}" cy="${cy}" r="3.2" fill="${hrtScoreColor(x.score)}"></circle>`;
+  }).join('');
+  const y100 = yOf(100), y65 = yOf(65), y40 = yOf(40), y0 = yOf(0);
+  return `<svg class="hrt-chart" viewBox="0 0 300 110" preserveAspectRatio="none" aria-label="График самочувствия">
