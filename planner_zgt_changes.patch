+async function exportHrtData() {
+  const entries = state.zgtEntries || [];
+  const labs = state.estradiolEntries || [];
+  let out = 'ТРЕКЕР ЗГТ — дневник самочувствия\n\n';
+  if (labs.length) {
+    out += 'ЭСТРАДИОЛ:\n';
+    labs.forEach(e => { out += `  ${e.date}: ${e.val} пг/мл${e.note ? ` (${e.note})` : ''}\n`; });
+    out += '\n';
+  }
+  entries.forEach(entry => {
+    out += `${entry.date} (день ${entry.day || '—'}):\n`;
+    HRT_ALL.forEach(item => {
+      if (entry[item.id] !== undefined) out += `  ${item.name}: ${item.labels[entry[item.id]]}\n`;
+    });
+    if (entry.note) out += `  Заметка: ${entry.note}\n`;
+    out += '\n';
+  });
+  try {
+    await navigator.clipboard.writeText(out);
+    showHrtMessage('✓ Скопировано', false, 'export');
+  } catch (error) {
+    const blob = new Blob([out], { type: 'text/plain;charset=utf-8' });
+    const url = URL.createObjectURL(blob);
+    const link = document.createElement('a');
+    link.href = url;
+    link.download = 'zgt-tracker.txt';
+    link.click();
+    URL.revokeObjectURL(url);
+    showHrtMessage('Файл с данными создан', false, 'export');
+  }
