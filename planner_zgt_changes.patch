+    <rect x="0" y="${y65}" width="300" height="${y40-y65}" fill="rgba(217,164,65,.13)"></rect>
+    <rect x="0" y="${y40}" width="300" height="${y0-y40}" fill="rgba(168,62,48,.10)"></rect>
+    <polyline points="${points}" fill="none" stroke="var(--rose-deep)" stroke-width="2"></polyline>${dots}
+  </svg>
+  <div class="hrt-chart-labels"><span>${hrtFmtDate(scored[0].date)}</span><span>${hrtFmtDate(scored[scored.length-1].date)}</span></div>`;
+}
