+// ====== HRT / ЗГТ ======
+function hrtFmtDate(dateStr) {
+  if (!dateStr) return '—';
+  const [y,m,d] = dateStr.split('-').map(Number);
+  const dt = new Date(y, (m || 1)-1, d || 1);
+  return `${dt.getDate()} ${MONTHS_SHORT[dt.getMonth()]} ${dt.getFullYear()}`;
+}
+
+function hrtWellnessScore(entry) {
+  let total = 0, count = 0;
+  HRT_SYMPTOMS.forEach(item => {
+    if (entry[item.id] !== undefined && entry[item.id] !== null) {
+      total += ((2 - Number(entry[item.id])) / 2) * 100;
+      count++;
+    }
+  });
+  HRT_GOODS.forEach(item => {
+    if (entry[item.id] !== undefined && entry[item.id] !== null) {
+      total += (Number(entry[item.id]) / 2) * 100;
+      count++;
+    }
+  });
+  return count ? Math.round(total / count) : null;
+}
+
+function hrtScoreColor(score) {
+  if (score === null || score === undefined) return 'var(--ink-muted)';
+  if (score >= 65) return '#5F8C84';
+  if (score >= 40) return '#C79020';
+  return '#A83E30';
+}
+
+function reindexHrtDays(entries) {
+  const sorted = entries.slice().sort((a,b) => String(a.date).localeCompare(String(b.date)));
+  if (!sorted.length) return sorted;
+  const [sy,sm,sd] = sorted[0].date.split('-').map(Number);
+  const start = new Date(sy, sm-1, sd);
+  return sorted.map(entry => {
+    const [y,m,d] = entry.date.split('-').map(Number);
+    const day = Math.max(1, Math.floor((new Date(y,m-1,d) - start) / 86400000) + 1);
+    return { ...entry, day };
+  });
+}
+
+function hrtDayNumber(dateStr) {
+  const entries = state.zgtEntries || [];
+  const firstDate = entries.length ? entries[0].date : dateStr;
+  if (!firstDate || !dateStr) return 1;
+  const [fy,fm,fd] = firstDate.split('-').map(Number);
+  const [y,m,d] = dateStr.split('-').map(Number);
+  return Math.max(1, Math.floor((new Date(y,m-1,d) - new Date(fy,fm-1,fd)) / 86400000) + 1);
+}
+
