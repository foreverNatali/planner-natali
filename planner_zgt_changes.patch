+      <rect x="0" y="${zoneTop}" width="300" height="${Math.max(0, zoneBottom-zoneTop)}" fill="rgba(95,140,132,.16)"></rect>
+      <polyline points="${points}" fill="none" stroke="var(--rose-deep)" stroke-width="2"></polyline>${dots}
+    </svg>
+    <div class="hrt-chart-labels"><span>${hrtFmtDate(entries[0].date)}</span><span>${hrtFmtDate(entries[entries.length-1].date)}</span></div>
+    <div style="text-align:center;color:var(--ink-muted);font-size:10px;margin-top:8px">зелёная зона — ориентир 40–80 пг/мл из исходного трекера</div>
